{
	"name": "api-boilerplate",
	"version": "1.0.0",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"build": "tsc && tsc-alias",
		"typecheck": "tsc --noEmit",
		"start": "node dist/server.js",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"lint": "biome check --write .",
		"generate:module": "tsx scripts/generate-module.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"prepare": "husky"
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@fastify/helmet": "^13.0.2",
		"@fastify/rate-limit": "^11.0.0",
		"@fastify/swagger": "^9.0.0",
		"@scalar/fastify-api-reference": "^1.25.0",
		"@sentry/node": "^10.59.0",
		"@sinclair/typebox": "^0.34.49",
		"awilix": "^13.0.3",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"fastify": "^5.0.0",
		"fastify-plugin": "^5.0.0",
		"firebase-admin": "^13.10.0",
		"ioredis": "^5.11.1",
		"pg": "^8.12.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/pg": "^8.11.0",
		"@vitest/coverage-v8": "^2.1.9",
		"drizzle-kit": "^0.31.10",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"tsc-alias": "^1.8.17",
		"tsx": "^4.19.0",
		"typescript": "^6.0.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^2.1.9"
	},
	"lint-staged": {
		"src/**/*.ts": "biome check --write"
	}
}
