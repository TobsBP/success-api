# Server port
PORT=3000

# DB connection
DATABASE_URL=postgresql://user:pass@localhost:5432/db

# Firebase auth
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_API_KEY=your-web-api-key

# Opcional: if empty, Sentry off
SENTRY_DSN=

# Optional: if empty, cache is disabled (no-op)
REDIS_URL=redis://localhost:6379

# Rate limit (global)
RATE_LIMIT_MAX=50
RATE_LIMIT_WINDOW=1 minute

# Assistant: which LLM provider to use ("claude" or "gemini", defaults to claude)
AI_PROVIDER=claude
# Optional: only the key for the selected AI_PROVIDER is required; the assistant
# module returns a clear error when the corresponding key is missing
ANTHROPIC_API_KEY=
GEMINI_API_KEY=